<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_step_action_popup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="26dp"
        app:cardElevation="8dp"
        app:contentPaddingBottom="6dp"
        app:contentPaddingLeft="6dp"
        app:contentPaddingRight="6dp"
        app:contentPaddingTop="6dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/button_toggle_step_enabled"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/desc_disable_action"
                android:src="@drawable/rounded_pause_24"
                app:tint="?attr/colorOnSecondaryContainer" />

            <ImageButton
                android:id="@+id/button_restore_block_action"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/desc_restore_block_action"
                android:src="@drawable/rounded_reset_iso_24"
                android:visibility="gone"
                app:tint="?attr/colorOnPrimaryContainer" />

            <ImageButton
                android:id="@+id/button_insert_below_action"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/insert_below"
                android:src="@drawable/rounded_splitscreen_add_24"
                app:tint="?attr/colorOnPrimaryContainer" />

            <ImageButton
                android:id="@+id/button_duplicate_action"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/common_copy"
                android:src="@drawable/rounded_content_copy_24"
                app:tint="?attr/colorOnTertiaryContainer" />

            <ImageButton
                android:id="@+id/button_delete_action"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/desc_delete_action"
                android:src="@drawable/rounded_delete_24"
                app:tint="?attr/colorOnErrorContainer" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
