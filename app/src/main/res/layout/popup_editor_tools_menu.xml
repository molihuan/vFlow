<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="horizontal">

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/card_editor_tools_popup"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="?attr/colorSurfaceContainerHigh"
        app:cardCornerRadius="26dp"
        app:cardElevation="8dp"
        app:contentPaddingBottom="6dp"
        app:contentPaddingLeft="6dp"
        app:contentPaddingRight="6dp"
        app:contentPaddingTop="6dp"
        app:strokeColor="?attr/colorOutlineVariant"
        app:strokeWidth="1dp">

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/button_redo_edit"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginEnd="6dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/workflow_editor_redo"
                android:src="@drawable/rounded_redo_24"
                app:tint="?attr/colorOnPrimaryContainer" />

            <ImageButton
                android:id="@+id/button_enter_selection_mode"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:background="@drawable/bg_step_popup_action_button"
                android:contentDescription="@string/editor_selection_mode"
                android:src="@drawable/rounded_list_alt_check_24"
                app:tint="?attr/colorOnPrimaryContainer" />
        </LinearLayout>
    </com.google.android.material.card.MaterialCardView>
</LinearLayout>
